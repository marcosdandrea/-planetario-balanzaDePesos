#APP
USE_AUTHENTICATION=true

#SECURITY
LOCALHOST_ONLY=true
USE_CONTEXT_ISOLATION=false
PUBLIC_ENDPOINTS=[/public]

#DEVELOPMENT
VITE_DEV_PORT=5123
INCREMENT_PATCH_VERSION_ON_BUILD=true

#SERVER
MAIN_SERVER_PORT=3000

#SCALE SERIAL
SCALE_SERIAL_ENABLED=true
SCALE_SERIAL_PORT=auto
SCALE_SERIAL_BAUD_RATE=9600
SCALE_SERIAL_POLL_INTERVAL_MS=40
SCALE_SERIAL_REQUEST_COMMAND=\x05
SCALE_SERIAL_MIN_DELTA=0.5

#LOGGING
WRITE_LOG_TO_FILE=false
WRITE_LOG_LEVEL=info
